# Production Environment Variables Template
# Copy this file and set real values for your production deployment

# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Configuration
# Use MongoDB Atlas (Cloud) - mongodb+srv://username:password@cluster.mongodb.net/dbname
# Replace username, password, cluster name, and database name
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/bar_restaurant_db

# JWT Configuration
# Generate a strong random secret key (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Frontend URL (for CORS)
# This should be your Vercel deployment URL or your custom domain
FRONTEND_URL=https://your-frontend-vercel.app

# Email Configuration (Optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourrestaurant.com

# Application URL (for email links, etc.)
APP_URL=https://your-api-domain.onrender.com

# When debugging frontend CORS issues, you can temporarily bypass origin checks by
# setting the following to `true`. **Do not enable this in production**.
ALLOW_ALL_ORIGINS=false
